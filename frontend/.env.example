# ── API ───────────────────────────────────────────────────────────────────────
# Full URL of the deployed FastAPI backend (no trailing slash).
# In local dev this is not needed — the Vite proxy handles /api → localhost:8000.
# In production (Vercel) set this to your Render backend URL, e.g.:
# VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=

# ── App metadata (optional) ───────────────────────────────────────────────────
VITE_APP_TITLE=Complaint Management System
